// This schema uses SQLite so you can run the project with zero setup.
// For your submitted / deployed version, switch the datasource to Postgres:
//
//   datasource db {
//     provider = "postgresql"
//     url      = env("DATABASE_URL")   // e.g. postgresql://user:pass@host:5432/dbname
//   }
//
// then run `npx prisma migrate dev` again.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Participant {
  id        String   @id @default(cuid())
  name      String
  groupId   String
  createdAt DateTime @default(now())

  debtsFrom Debt[] @relation("DebtFrom")
  debtsTo   Debt[] @relation("DebtTo")
}

model Debt {
  id        String   @id @default(cuid())
  groupId   String
  fromId    String
  toId      String
  amount    Float
  createdAt DateTime @default(now())

  from Participant @relation("DebtFrom", fields: [fromId], references: [id])
  to   Participant @relation("DebtTo", fields: [toId], references: [id])
}

model Settlement {
  id        String   @id @default(cuid())
  groupId   String
  result    String // JSON-encoded array of { from, to, amount }
  createdAt DateTime @default(now())
}
